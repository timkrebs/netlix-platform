resource_changes = {
	"aws_vpc.main": {
		"type":          "aws_vpc",
		"provider_name": "registry.terraform.io/hashicorp/aws",
		"mode":          "managed",
		"change": {
			"actions": ["create"],
			"after": {
				"cidr_block": "10.0.0.0/16",
			},
		},
	},
	"aws_flow_log.main": {
		"type":          "aws_flow_log",
		"provider_name": "registry.terraform.io/hashicorp/aws",
		"mode":          "managed",
		"change": {
			"actions": ["create"],
			"after": {
				"traffic_type":    "ALL",
				"log_destination": "arn:aws:s3:::flow-logs-bucket",
			},
		},
	},
}
